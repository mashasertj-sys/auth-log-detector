# Создай файл, если его нет
touch .gitignore

# Открой и добавь:
cat > .gitignore << 'EOF'
# Виртуальное окружение
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# База данных и логи
*.db
*.log
*.json
!rules.yaml

# Секреты
.env
*.env
*.pem
*.key

# Docker
.docker/
!Dockerfile
!docker-compose.yml

# Отчёты (опционально)
reports/

# IDE
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# macOS
.DS_Store
*.zip
*.tar.gz
ngrok
ngrok.zip
EOF